<script>
// ============================================
// 音频系统 - Web Audio API
// ============================================
const AudioSystem = {
  ctx: null,
  bgMusic: null,
  bgGain: null,
  sfxGain: null,
  musicOn: true,
  sfxOn: true,

  init() {
    if (this.ctx) return;
    this.ctx = new (window.AudioContext || window.webkitAudioContext)();
    this.sfxGain = this.ctx.createGain();
    this.sfxGain.gain.value = 0.3;
    this.sfxGain.connect(this.ctx.destination);
    this.bgGain = this.ctx.createGain();
    this.bgGain.gain.value = 0.08;
    this.bgGain.connect(this.ctx.destination);
  },

  playNote(freq, duration, type = 'sine', gainVal = 0.3) {
    if (!this.sfxOn || !this.ctx) return;
    const osc = this.ctx.createOscillator();
    const g = this.ctx.createGain();
    osc.type = type;
    osc.frequency.value = freq;
    g.gain.setValueAtTime(gainVal, this.ctx.currentTime);
    g.gain.exponentialRampToValueAtTime(0.001, this.ctx.currentTime + duration);
    osc.connect(g);
    g.connect(this.sfxGain);
    osc.start();
    osc.stop(this.ctx.currentTime + duration);
  },

  correct() {
    this.playNote(523, 0.15, 'sine');
    setTimeout(() => this.playNote(659, 0.15, 'sine'), 100);
    setTimeout(() => this.playNote(784, 0.3, 'sine'), 200);
  },

  wrong() {
    this.playNote(200, 0.3, 'sawtooth', 0.15);
    setTimeout(() => this.playNote(160, 0.4, 'sawtooth', 0.1), 150);
  },

  click() { this.playNote(800, 0.06, 'sine', 0.15); },

  levelUp() {
    [523, 587, 659, 784, 880, 1047].forEach((f, i) => {
      setTimeout(() => this.playNote(f, 0.2, 'sine', 0.25), i * 80);
    });
  },

  spin() {
    this.playNote(300, 0.05, 'sine', 0.1);
  },

  achievement() {
    [784, 988, 1175, 1319].forEach((f, i) => {
      setTimeout(() => this.playNote(f, 0.3, 'triangle', 0.2), i * 120);
    });
  },

  startBgMusic() {
    if (!this.ctx || this.bgMusic) return;
    const notes = [261, 329, 392, 523, 392, 329, 261, 196, 261, 329, 392, 440, 523, 440, 392, 329];
    let idx = 0;
    const playNext = () => {
      if (!this.musicOn) return;
      const osc = this.ctx.createOscillator();
      const g = this.ctx.createGain();
      osc.type = 'sine';
      osc.frequency.value = notes[idx % notes.length];
      g.gain.setValueAtTime(0.06, this.ctx.currentTime);
      g.gain.exponentialRampToValueAtTime(0.001, this.ctx.currentTime + 0.8);
      osc.connect(g);
      g.connect(this.bgGain);
      osc.start();
      osc.stop(this.ctx.currentTime + 0.9);
      idx++;
      this.bgMusic = setTimeout(playNext, 500);
    };
    playNext();
  },

  stopBgMusic() {
    clearTimeout(this.bgMusic);
    this.bgMusic = null;
  },

  toggleMusic() {
    this.musicOn = !this.musicOn;
    if (this.musicOn) this.startBgMusic();
    else this.stopBgMusic();
    return this.musicOn;
  },

  toggleSfx() {
    this.sfxOn = !this.sfxOn;
    return this.sfxOn;
  }
};

