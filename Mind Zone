  .safe-bottom { padding-bottom: max(90px, calc(env(safe-area-inset-bottom) + 80px)); }

  /* 输入框 */
  .input-field {
    background: var(--glass);
    border: 1px solid var(--card-border);
    border-radius: 14px;
    padding: 14px 18px;
    color: var(--text);
