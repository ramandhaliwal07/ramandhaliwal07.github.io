// ============================================
// 主渲染函数
// ============================================
function render() {
  const app = document.getElementById('app');
  const page = State.currentPage;

  // 主题切换
  if (State.darkMode) {
    document.documentElement.classList.add('dark');
    document.body.classList.remove('light-mode');
  } else {
    document.documentElement.classList.remove('dark');
    document.body.classList.add('light-mode');
  }

  let html = '';
  switch (page) {
    case 'welcome': html = renderWelcome(); break;
    case 'home': html = renderHome(); break;
    case 'games': html = renderGames(); break;
    case 'categories': html = renderCategories(); break;
    case 'leaderboard': html = renderLeaderboard(); break;
    case 'profile': html = renderProfile(); break;
    case 'settings': html = renderSettings(); break;
    case 'rewards': html = renderRewards(); break;
    case 'certificates': html = renderCertificates(); break;
    case 'game_select': html = renderGameSelect(); break;
    case 'playing': html = renderPlaying(); break;
    case 'game_result': html = renderGameResult(); break;
    case 'daily_challenge': html = renderDailyChallenge(); break;
    case 'spin_wheel': html = renderSpinWheel(); break;
    case 'memory_game': html = renderMemoryGame(); break;
    case 'math_battle': html = renderMathBattle(); break;
    case 'time_attack': html = renderTimeAttack(); break;
    case 'true_false': html = renderTrueFalse(); break;
    case 'parent_dashboard': html = renderParentDashboard(); break;
    case 'teacher_dashboard': html = renderTeacherDashboard(); break;
    default: html = renderHome();
  }

  app.innerHTML = `<div class="page-enter">${html}</div>`;

  // 绑定事件
  setTimeout(() => bindEvents(), 50);
}

