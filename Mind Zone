            <i class="fa-solid fa-clock mr-1" style="color: var(--accent);"></i>${timeElapsed}s
          </span>
        </div>
      </div>

      <div class="flex-1 flex items-center justify-center px-5 py-4">
        <div class="grid gap-2.5" style="grid-template-columns: repeat(${cols}, 1fr); max-width: 360px; width: 100%;">
          ${memoryState.cards.map((card, i) => {
            const isFlipped = memoryState.flipped.includes(i) || memoryState.matched.includes(i);
            const isMatched = memoryState.matched.includes(i);
            return `
              <div class="memory-card ${isFlipped ? 'flipped' : ''}" onclick="flipMemoryCard(${i})" style="aspect-ratio: 1;">
                <div class="memory-card-inner w-full h-full">
                  <div class="memory-card-front" style="background: linear-gradient(135deg, #7c3aed, #06b6d4); border: 2px solid rgba(255,255,255,0.1);">
                    <i class="fa-solid fa-question text-white text-lg"></i>
                  </div>
                  <div class="memory-card-back" style="background: ${isMatched ? 'rgba(16,185,129,0.2)' : 'var(--card)'}; border: 2px solid ${isMatched ? '#10b981' : 'var(--card-border)'};">
                    <span class="text-3xl">${card}</span>
                  </div>
                </div>
              </div>
            `;
          }).join('')}
        </div>
      </div>

      ${memoryState.matched.length === memoryState.cards.length ? `
        <div class="px-5 pb-6">
          <div class="glass-strong p-5 text-center">
            <h2 class="font-display font-bold text-xl mb-2" style="color: #10b981;">${t('congratulations')}</h2>
            <p class="text-sm mb-4" style="color: var(--text-muted);">Completed in ${memoryState.moves} moves and ${timeElapsed}s</p>
            <div class="flex gap-3">
              <button onclick="memoryState.cards=[]; render();" class="btn-glow flex-1 py-3 rounded-xl font-display font-semibold text-white"
                      style="background: linear-gradient(135deg, #7c3aed, #06b6d4);">
                Play Again
              </button>
              <button onclick="navigate('home')" class="btn-glow flex-1 py-3 rounded-xl font-display font-semibold" style="background: var(--glass); border: 1px solid var(--card-border);">
                Home
              </button>
            </div>
          </div>
        </div>
      ` : ''}
    </div>
  `;
}

function flipMemoryCard(idx) {
  if (!memoryState.canFlip) return;
  if (memoryState.flipped.includes(idx) || memoryState.matched.includes(idx)) return;

  AudioSystem.click();
  memoryState.flipped.push(idx);
  render();

  if (memoryState.flipped.length === 2) {
    memoryState.moves++;
    memoryState.canFlip = false;
    const [a, b] = memoryState.flipped;
    if (memoryState.cards[a] === memoryState.cards[b]) {
      AudioSystem.correct();
      memoryState.matched.push(a, b);
      memoryState.flipped = [];
      memoryState.canFlip = true;
      addXp(10);
      addCoins(3);
      setTimeout(() => render(), 300);
    } else {
      AudioSystem.wrong();
      setTimeout(() => {
        memoryState.flipped = [];
        memoryState.canFlip = true;
        render();
      }, 800);
    }
  }
}

