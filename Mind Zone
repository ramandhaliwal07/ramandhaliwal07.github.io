let memoryState = { cards: [], flipped: [], matched: [], moves: 0, canFlip: true, startTime: 0, pairs: 6 };

function initMemoryGame() {
  const emojis = ['🦊', '🦁', '🐼', '🦄', '🐙', '🦋', '🐬', '🦅', '🐸', '🐲', '🦉', '🐻'];
