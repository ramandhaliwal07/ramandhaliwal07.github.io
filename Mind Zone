    const isTrue = Math.random() > 0.5;
    return {
      statement: isTrue ? q.q : q.q.replace(q.options[q.answer], q.options[(q.answer + 1) % q.options.length]),
      isTrue,
      explanation: q.explanation,
      catName: q.catName
    };
  });
  tfState = { questions: shuffled, current: 0, score: 0, answered: false };
  navigate('true_false');
}

function renderTrueFalse() {
  const s = tfState;
  if (!s.questions.length) return renderHome();
  const q = s.questions[s.current];

  return `
    <div class="safe-top safe-bottom min-h-screen flex flex-col">
      <div class="flex items-center gap-3 px-5 py-3">
        <button onclick="navigate('home')" class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: var(--glass); border: 1px solid var(--card-border);">
          <i class="fa-solid fa-arrow-left text-sm"></i>
        </button>
        <h1 class="font-display font-bold text-lg flex-1">${t('trueOrFalse')}</h1>
        <span class="font-display font-bold">${s.current + 1}/${s.questions.length}</span>
      </div>

      <div class="flex-1 flex flex-col items-center justify-center px-5">
        <span class="text-xs font-medium px-3 py-1 rounded-full mb-4" style="background: var(--glass); color: var(--text-muted);">${q.catName}</span>

        <div class="glass-strong p-8 mb-8 w-full max-w-sm text-center" style="border: 1px solid var(--card-border);">
          <p class="font-display text-xl font-semibold leading-relaxed">${q.statement}</p>
        </div>

        <div class="flex gap-4 w-full max-w-sm mb-6">
          <button data-tf-ans="true" class="flex-1 py-5 rounded-2xl font-display font-bold text-lg text-white transition-all ${s.answered ? (q.isTrue ? 'ring-4 ring-green-400' : 'opacity-40') : ''}"
                  style="background: linear-gradient(135deg, #10b981, #059669);" ${s.answered ? 'disabled' : ''}>
            <i class="fa-solid fa-check mr-2"></i>True
          </button>
          <button data-tf-ans="false" class="flex-1 py-5 rounded-2xl font-display font-bold text-lg text-white transition-all ${s.answered ? (!q.isTrue ? 'ring-4 ring-red-400' : 'opacity-40') : ''}"
                  style="background: linear-gradient(135deg, #ef4444, #dc2626);" ${s.answered ? 'disabled' : ''}>
            <i class="fa-solid fa-xmark mr-2"></i>False
          </button>
        </div>

        ${s.answered ? `
          <div class="glass-sm p-4 w-full max-w-sm text-center">
            <p class="text-sm font-medium mb-1" style="color: ${s.lastCorrect ? '#10b981' : '#ef4444'};">
              ${s.lastCorrect ? t('correct') : t('wrong')}! The statement is ${q.isTrue ? 'TRUE' : 'FALSE'}.
            </p>
            <p class="text-sm" style="color: var(--text-muted);">${q.explanation}</p>
            <button onclick="tfNext()" class="btn-glow w-full py-3 rounded-xl font-display font-semibold text-white mt-4"
                    style="background: linear-gradient(135deg, #7c3aed, #06b6d4);">
              ${s.current < s.questions.length - 1 ? t('next') : t('finish')}
            </button>
          </div>
        ` : ''}
      </div>
    </div>
  `;
}

function tfNext() {
  tfState.current++;
  tfState.answered = false;
  if (tfState.current >= tfState.questions.length) {
    const score = tfState.score;
    addXp(score * 10);
    addCoins(score * 5);
    showToast(`Score: ${score}/${tfState.questions.length}`, 'success');
    navigate('home');
  } else {
    render();
  }
}

