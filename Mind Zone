// ============================================
// MCQ 游戏主逻辑
// ============================================
let mcqState = { questions: [], current: 0, score: 0, answered: false, selectedIdx: -1, startTime: 0, difficulty: 'easy' };

function startMCQGame(catId, difficulty, questionCount) {
  const allQ = getQuestions(catId);
  const shuffled = [...allQ].sort(() => Math.random() - 0.5);
  const count = Math.min(questionCount || 5, shuffled.length);
  mcqState = {
    questions: shuffled.slice(0, count),
    current: 0,
    score: 0,
    answered: false,
    selectedIdx: -1,
    startTime: Date.now(),
    difficulty: difficulty || 'easy',
    catId: catId,
  };
  navigate('playing');
}

function renderPlaying() {
  const s = mcqState;
  if (!s.questions.length) return renderHome();
  const q = s.questions[s.current];
  const total = s.questions.length;
  const progress = ((s.current) / total) * 100;
  const timeElapsed = Math.floor((Date.now() - s.startTime) / 1000);
  const minutes = Math.floor(timeElapsed / 60);
  const seconds = timeElapsed % 60;

  return `
    <div class="safe-top safe-bottom min-h-screen flex flex-col">
      <!-- 顶部栏 -->
      <div class="flex items-center gap-3 px-5 py-3">
        <button onclick="navigate('game_select', {catId: '${s.catId}'})" class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: var(--glass); border: 1px solid var(--card-border);">
          <i class="fa-solid fa-xmark text-sm"></i>
        </button>
        <div class="flex-1">
          <div class="h-2 rounded-full overflow-hidden" style="background: var(--glass);">
            <div class="progress-fill h-full rounded-full" style="width: ${progress}%; background: linear-gradient(90deg, #7c3aed, #06b6d4);"></div>
          </div>
        </div>
        <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-xl" style="background: var(--glass);">
          <i class="fa-solid fa-clock text-xs" style="color: var(--accent);"></i>
          <span class="text-xs font-medium">${minutes}:${seconds.toString().padStart(2, '0')}</span>
        </div>
      </div>

      <!-- 题号 -->
      <div class="px-5 mb-4">
        <span class="text-xs font-medium px-3 py-1 rounded-full" style="background: var(--glass); color: var(--text-muted);">
          ${s.current + 1} / ${total}
        </span>
        <span class="text-xs ml-2 px-3 py-1 rounded-full" style="background: ${s.difficulty === 'easy' ? 'rgba(16,185,129,0.15)' : s.difficulty === 'medium' ? 'rgba(245,158,11,0.15)' : s.difficulty === 'hard' ? 'rgba(249,115,22,0.15)' : 'rgba(239,68,68,0.15)'}; color: ${s.difficulty === 'easy' ? '#10b981' : s.difficulty === 'medium' ? '#f59e0b' : s.difficulty === 'hard' ? '#f97316' : '#ef4444'};">
          ${t(s.difficulty)}
        </span>
