  .font-display { font-family: 'Fredoka', sans-serif; }

  /* 滚动条 */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--accent2); border-radius: 4px; }

  /* 玻璃态卡片 */
  .glass {
    background: var(--card);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--card-border);
    border-radius: 20px;
  }
  .glass-sm {
    background: var(--glass);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--card-border);
    border-radius: 14px;
  }
  .glass-strong {
    background: rgba(10, 14, 39, 0.85);
    backdrop-filter: blur(30px);
    -webkit-backdrop-filter: blur(30px);
    border: 1px solid rgba(124, 58, 237, 0.3);
    border-radius: 24px;
  }
  .light-mode .glass-strong {
    background: rgba(255, 255, 255, 0.9);
  }

  /* 背景动效 */
  .bg-orbs {
    position: fixed; inset: 0; z-index: 0; pointer-events: none; overflow: hidden;
  }
  .bg-orbs .orb {
    position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.3;
    animation: orbFloat 20s ease-in-out infinite alternate;
  }
  .bg-orbs .orb:nth-child(1) {
    width: 400px; height: 400px; background: #7c3aed;
    top: -100px; left: -100px; animation-delay: 0s;
  }
  .bg-orbs .orb:nth-child(2) {
    width: 350px; height: 350px; background: #06b6d4;
    bottom: -80px; right: -80px; animation-delay: -7s;
  }
  .bg-orbs .orb:nth-child(3) {
    width: 250px; height: 250px; background: #ec4899;
    top: 40%; left: 60%; animation-delay: -14s; opacity: 0.15;
  }
  @keyframes orbFloat {
    0% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, -40px) scale(1.1); }
    66% { transform: translate(-20px, 30px) scale(0.9); }
    100% { transform: translate(10px, -10px) scale(1.05); }
  }

  /* 粒子 */
  .particles {
    position: fixed; inset: 0; z-index: 0; pointer-events: none;
  }
  .particle {
    position: absolute; width: 3px; height: 3px; background: var(--accent);
    border-radius: 50%; opacity: 0.4;
    animation: particleDrift linear infinite;
  }
  @keyframes particleDrift {
    0% { transform: translateY(100vh) rotate(0deg); opacity: 0; }
    10% { opacity: 0.4; }
    90% { opacity: 0.4; }
    100% { transform: translateY(-10vh) rotate(360deg); opacity: 0; }
  }

  /* 页面过渡 */
  .page-enter { animation: pageIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  .page-exit { animation: pageOut 0.3s cubic-bezier(0.55, 0, 1, 0.45) forwards; }
  @keyframes pageIn {
    from { opacity: 0; transform: translateY(30px) scale(0.97); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  @keyframes pageOut {
    from { opacity: 1; transform: translateY(0) scale(1); }
    to { opacity: 0; transform: translateY(-20px) scale(0.97); }
  }

  /* 按钮效果 */
  .btn-glow {
    position: relative; overflow: hidden;
    transition: all 0.3s ease;
  }
  .btn-glow::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(6,182,212,0.2), rgba(124,58,237,0.2));
    opacity: 0; transition: opacity 0.3s;
  }
  .btn-glow:hover::after, .btn-glow:active::after { opacity: 1; }
  .btn-glow:active { transform: scale(0.96); }

  /* 卡片悬浮 */
  .card-hover {
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .card-hover:hover, .card-hover:active {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(124, 58, 237, 0.15), 0 0 0 1px rgba(6,182,212,0.2);
  }

  /* 进度条动画 */
  .progress-fill {
    transition: width 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* 脉冲 */
  .pulse-glow {
    animation: pulseGlow 2s ease-in-out infinite;
  }
  @keyframes pulseGlow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(6,182,212,0.4); }
    50% { box-shadow: 0 0 0 12px rgba(6,182,212,0); }
  }

  /* 旋转轮盘 */
  .spin-wheel {
    transition: transform 4s cubic-bezier(0.17, 0.67, 0.12, 0.99);
  }

  /* 记忆卡片翻转 */
  .memory-card { perspective: 600px; }
  .memory-card-inner {
    transition: transform 0.5s ease;
    transform-style: preserve-3d;
  }
  .memory-card.flipped .memory-card-inner { transform: rotateY(180deg); }
  .memory-card-front, .memory-card-back {
    backface-visibility: hidden;
    position: absolute; inset: 0; border-radius: 16px;
    display: flex; align-items: center; justify-content: center;
  }
  .memory-card-back { transform: rotateY(180deg); }

  /* 拖拽 */
  .drag-item {
    cursor: grab; user-select: none; touch-action: none;
  }
  .drag-item:active { cursor: grabbing; }
  .drag-over {
    border-color: var(--accent) !important;
    background: rgba(6, 182, 212, 0.1) !important;
  }

  /* 底部导航 */
  .bottom-nav {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 50;
    padding: 8px 12px; padding-bottom: max(8px, env(safe-area-inset-bottom));
  }
  .nav-item {
    display: flex; flex-direction: column; align-items: center; gap: 2px;
    padding: 6px 12px; border-radius: 14px;
    transition: all 0.3s ease; color: var(--text-muted);
    font-size: 10px; font-weight: 500; cursor: pointer;
    position: relative;
  }
  .nav-item.active {
    color: var(--accent);
    background: rgba(6, 182, 212, 0.1);
  }
  .nav-item.active::before {
    content: ''; position: absolute; top: -8px; left: 50%; transform: translateX(-50%);
    width: 20px; height: 3px; background: var(--accent); border-radius: 3px;
  }
  .nav-item i { font-size: 20px; margin-bottom: 1px; }

  /* Toast */
  .toast {
    position: fixed; top: 20px; left: 50%; transform: translateX(-50%) translateY(-100px);
    z-index: 999; padding: 14px 24px; border-radius: 16px;
    font-weight: 500; font-size: 14px;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    max-width: 90vw; text-align: center;
  }
  .toast.show { transform: translateX(-50%) translateY(0); }

  /* XP弹出 */
