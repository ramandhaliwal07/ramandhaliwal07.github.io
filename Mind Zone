let mathBattleState = { current: null, score: 0, round: 0, totalRounds: 10, timeLeft: 15, timer: null, answered: false, streak: 0 };

function generateMathProblem() {
  const ops = ['+', '-', '×'];
  const op = ops[Math.floor(Math.random() * ops.length)];
  let a, b, answer;
  switch (op) {
    case '+': a = Math.floor(Math.random() * 50) + 1; b = Math.floor(Math.random() * 50) + 1; answer = a + b; break;
    case '-': a = Math.floor(Math.random() * 50) + 10; b = Math.floor(Math.random() * a) + 1; answer = a - b; break;
    case '×': a = Math.floor(Math.random() * 12) + 2; b = Math.floor(Math.random() * 12) + 2; answer = a * b; break;
  }
  // 生成干扰选项
  const options = new Set([answer]);
  while (options.size < 4) {
    const offset = Math.floor(Math.random() * 20) - 10;
    if (offset !== 0) options.add(answer + offset);
  }
  return { q: `${a} ${op} ${b} = ?`, answer, options: [...options].sort(() => Math.random() - 0.5) };
}

function startMathBattle() {
  mathBattleState = { current: generateMathProblem(), score: 0, round: 0, totalRounds: 10, timeLeft: 15, timer: null, answered: false, streak: 0 };
  navigate('math_battle');
}

