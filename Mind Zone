    background: var(--glass);
    border: 1px solid var(--card-border);
    border-radius: 14px;
    padding: 12px 16px;
    color: var(--text);
    outline: none;
    width: 100%;
    font-family: inherit;
    font-size: 14px;
    transition: all 0.3s;
