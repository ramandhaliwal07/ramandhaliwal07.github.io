  .input-field:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(6, 182, 212, 0.15);
  }
  .input-field::placeholder { color: var(--text-muted); }

  /* 选项按钮 */
  .option-btn {
