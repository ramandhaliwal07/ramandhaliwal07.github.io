  gameData: null,
  toasts: [],
};

function t(key) { return i18n[State.language][key] || i18n['en'][key] || key; }

function getUserData() {
  try {
    const d = localStorage.getItem('mindquest_user');
    return d ? JSON.parse(d) : null;
  } catch { return null; }
}

function saveUserData(data) {
  try { localStorage.setItem('mindquest_user', JSON.stringify(data)); } catch {}
}

function getAgeGroup(age) {
  if (age >= 3 && age <= 6) return '3-6';
  if (age >= 7 && age <= 12) return '7-12';
  if (age >= 13 && age <= 18) return '13-18';
  return '18+';
}

function getCategories() {
  if (!State.user) return [];
  const group = getAgeGroup(State.user.age);
  return LearningContent[group]?.categories || [];
}

function getQuestions(catId) {
  if (!State.user) return [];
  const group = getAgeGroup(State.user.age);
  return LearningContent[group]?.questions?.[catId] || [];
}

function getXpForLevel(level) { return level * 100; }

function addXp(amount) {
  if (!State.user) return;
  State.user.xp += amount;
  const needed = getXpForLevel(State.user.level);
  let leveledUp = false;
  while (State.user.xp >= needed) {
    State.user.xp -= getXpForLevel(State.user.level);
    State.user.level++;
    leveledUp = true;
  }
  saveUserData(State.user);
  if (leveledUp) {
    AudioSystem.levelUp();
    showToast(`${t('newLevel')} ${State.user.level}`, 'success');
  }
}

function addCoins(amount) {
  if (!State.user) return;
  State.user.coins += amount;
  saveUserData(State.user);
}

function updateStreak() {
  if (!State.user) return;
  const today = new Date().toDateString();
  if (State.user.lastPlayDate === today) return;
  const yesterday = new Date(Date.now() - 86400000).toDateString();
  if (State.user.lastPlayDate === yesterday) {
    State.user.streak++;
  } else if (State.user.lastPlayDate !== today) {
    State.user.streak = 1;
  }
  State.user.lastPlayDate = today;
  saveUserData(State.user);
}

function recordGameResult(catId, correct, total, timeTaken) {
  if (!State.user) return;
  if (!State.user.gameHistory) State.user.gameHistory = [];
  if (!State.user.categoryProgress) State.user.categoryProgress = {};
  if (!State.user.categoryProgress[catId]) {
    State.user.categoryProgress[catId] = { played: 0, correct: 0, total: 0, bestScore: 0 };
  }
  const cp = State.user.categoryProgress[catId];
  cp.played++;
  cp.correct += correct;
  cp.total += total;
  const score = Math.round((correct / total) * 100);
  if (score > cp.bestScore) cp.bestScore = score;
  State.user.totalGames = (State.user.totalGames || 0) + 1;
  State.user.totalCorrect = (State.user.totalCorrect || 0) + correct;
  State.user.totalQuestions = (State.user.totalQuestions || 0) + total;
  State.user.gameHistory.unshift({
    catId, correct, total, score, timeTaken, date: new Date().toISOString()
  });
  if (State.user.gameHistory.length > 50) State.user.gameHistory.pop();
  saveUserData(State.user);
  checkBadges();
}

function checkBadges() {
  if (!State.user) return;
  if (!State.user.badges) State.user.badges = [];
  const u = State.user;
  const checks = [
    { id: 'first_game', cond: (u.totalGames || 0) >= 1 },
    { id: 'streak_3', cond: (u.streak || 0) >= 3 },
    { id: 'streak_7', cond: (u.streak || 0) >= 7 },
    { id: 'streak_30', cond: (u.streak || 0) >= 30 },
    { id: 'coins_100', cond: (u.coins || 0) >= 100 },
    { id: 'coins_1000', cond: (u.coins || 0) >= 1000 },
    { id: 'level_5', cond: u.level >= 5 },
    { id: 'level_10', cond: u.level >= 10 },
    { id: 'level_25', cond: u.level >= 25 },
    { id: 'games_10', cond: (u.totalGames || 0) >= 10 },
    { id: 'games_50', cond: (u.totalGames || 0) >= 50 },
  ];
  checks.forEach(c => {
    if (c.cond && !u.badges.includes(c.id)) {
      u.badges.push(c.id);
      const badge = Badges.find(b => b.id === c.id);
      if (badge) {
        AudioSystem.achievement();
        showToast(`Badge Unlocked: ${badge.name}!`, 'achievement');
      }
    }
  });
  saveUserData(u);
}

// ============================================
